Процедура ОтладкаВывестиСтруктуру(Данные, Заголовок)
	Если Заголовок <> Неопределено Тогда
		Сообщить("=== " + Заголовок + " ===");
	КонецЕсли;
	Если ТипЗнч(Данные) = Тип("Структура") Или ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Для Каждого КлючЗначение Из Данные Цикл
			Сообщить(КлючЗначение.Ключ + ": " + КлючЗначение.Значение);
		КонецЦикла;
	ИначеЕсли ТипЗнч(Данные) = Тип("Массив") Тогда
		Для Счетчик = 0 По Данные.Количество() - 1 Цикл
			Сообщить("[" + Счетчик + "]: " + Данные[Счетчик]);
		КонецЦикла;
	Иначе
		Сообщить(Данные);
	КонецЕсли;
КонецПроцедуры
Процедура ОтладкаЗамеритьВремя(ИмяОперации)
	Ключ = "Замер_" + ИмяОперации;
	Если Не ЗначениеЗаполнено(Ключ) Тогда
		Кэш = Новый КэшДанных;
		Кэш.Установить(Ключ, ТекущаяДата());
	КонецЕсли;
КонецПроцедуры
