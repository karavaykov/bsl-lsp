Процедура ВыполнитьРегламентныеЗадания()
	Отбор = Новый Структура;
	Отбор.Вставить("Использование", Истина);
	Задания = РегламентныеЗадания.ПолучитьЗадания(Отбор);
	Для Каждого Задание Из Задания Цикл
		Попытка
			Задание.Выполнить();
			ЗаписьЖурналаРегистрации("Информация", "РегламентноеЗадание", , "Выполнено задание: " + Задание.Наименование);
		Исключение
			ЗаписьЖурналаРегистрации("Ошибка", "РегламентноеЗадание", , "Ошибка выполнения задания: " + Задание.Наименование + " - " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры
Функция ПолучитьАктивныеЗадания()
	Отбор = Новый Структура;
	Отбор.Вставить("Использование", Истина);
	Отбор.Вставить("Состояние", СостояниеРегламентногоЗадания.Активно);
	Возврат РегламентныеЗадания.ПолучитьЗадания(Отбор);
КонецФункции
