Функция ПостроитьОтчетПоПродажам(ДатаНачала, ДатаКонца, Организация) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Продажи.Номенклатура КАК Товар,
	|	Продажи.Количество КАК Кол,
	|	Продажи.Сумма КАК Сумма,
	|	Продажи.Контрагент КАК Клиент
	|ИЗ Документ.РеализацияТоваров.Движения.Продажи КАК Продажи
	|ГДЕ Продажи.Период МЕЖДУ &Нач И &Кон
	|	И Продажи.Организация = &Организация
	|УПОРЯДОЧИТЬ ПО
	|	Продажи.Номенклатура,
	|	Продажи.Контрагент";
	Запрос.УстановитьПараметр("Нач", НачалоПериода);
	Запрос.УстановитьПараметр("Кон", КонецПериода);
	Запрос.УстановитьПараметр("Организация", Организация);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Товар");
	ТЗ.Колонки.Добавить("Количество");
	ТЗ.Колонки.Добавить("Сумма");
	ТЗ.Колонки.Добавить("Клиент");
	Пока Выборка.Следующий() Цикл
		Стр = ТЗ.Добавить();
		Стр.Товар = Выборка.Товар;
		Стр.Количество = Выборка.Кол;
		Стр.Сумма = Выборка.Сумма;
		Стр.Клиент = Выборка.Клиент;
	КонецЦикла;
	Возврат ТЗ;
КонецФункции
