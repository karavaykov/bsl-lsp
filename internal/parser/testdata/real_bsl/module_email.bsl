Процедура ОтправитьПисьмо(Кому, Тема, ТелоПисьма, Вложения) Экспорт
	Почта = Новый ИнтернетПочта;
	Почта.ИспользоватьSSLSocket = Истина;
	Почта.АдресСервераSMTP = "smtp.example.com";
	Почта.ПортSMTP = 465;
	Почта.ПользовательSMTP = "user@example.com";
	Почта.ПарольSMTP = "password";
	ПочтовоеСообщение = Новый ИнтернетПочтовоеСообщение;
	ПочтовоеСообщение.Тема = Тема;
	ПочтовоеСообщение.Тексты.Добавить(ТелоПисьма, ТипТекстаПочтовогоСообщения.ПростойТекст);
	ПочтовоеСообщение.Получатели.Добавить(Кому);
	Если Вложения <> Неопределено Тогда
		Для Каждого Файл Из Вложения Цикл
			ПочтовоеСообщение.Вложения.Добавить(Файл, ИмяФайлаИзСтроки(Файл));
		КонецЦикла;
	КонецЕсли;
	Попытка
		Почта.Послать(ПочтовоеСообщение);
	Исключение
		ВызватьИсключение "Ошибка отправки письма: " + ОписаниеОшибки();
	КонецПопытки;
КонецПроцедуры
