Процедура ПроверитьКонтрагента(ИНН, Наименование) Экспорт
	Если ПустаяСтрока(ИНН) Тогда
		ВызватьИсключение "ИНН не заполнен";
	КонецЕсли;
	Если СтрДлина(ИНН) <> 10 И СтрДлина(ИНН) <> 12 Тогда
		ВызватьИсключение "Некорректная длина ИНН";
	КонецЕсли;
	Найденные = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ИНН);
	Если Найденные.Количество() > 0 Тогда
		Существующий = Найденные.Получить(0);
		Если Существующий.Наименование <> Наименование Тогда
			ВызватьИсключение "Контрагент с ИНН " + ИНН + " уже существует с другим наименованием";
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
Функция ЗаполнитьПоИНН(ИНН) Экспорт
	ДанныеФНС = Новый ДанныеФНС;
	Попытка
		Результат = ДанныеФНС.ПолучитьДанныеПоИНН(ИНН);
		Если Результат.КодОшибки = 0 Тогда
			Возврат Результат;
		КонецЕсли;
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка", "ФНС", , "Ошибка получения данных по ИНН: " + ИНН);
	КонецПопытки;
	Возврат Неопределено;
КонецФункции
