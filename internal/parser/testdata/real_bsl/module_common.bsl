// Общий модуль с процедурами и функциями
Процедура ЗаполнитьРеквизиты(Объект, ЭкспортныеПараметры) Экспорт

	Если Не ПустаяСтрока(Объект.Наименование) Тогда
		СтандартнаяПодсистема.ВыполнитьМетод("ЗаполнитьНаименование", Объект);
	КонецЕсли;

	Для Каждого Строка Из Объект.Состав Цикл
		Строка.Цена = Объект.БазоваяЦена * (1 + Строка.Коэффициент / 100);
		Если Строка.Сумма > 0 И Строка.Количество = 0 Тогда
			ВызватьИсключение "Не указано количество для " + Строка.Наименование;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Функция РассчитатьСкидку(СуммаДокумента, ДатаДокумента) Экспорт

	Если СуммаДокумента >= 10000 Тогда
		БазоваяСкидка = 5;
	ИначеЕсли СуммаДокумента >= 5000 Тогда
		БазоваяСкидка = 3;
	Иначе
		БазоваяСкидка = 0;
	КонецЕсли;

	ДеньНедели = ДеньНедели(ДатаДокумента);
	Если ДеньНедели = 1 ИЛИ ДеньНедели = 7 Тогда
		БазоваяСкидка = БазоваяСкидка + 2;
	КонецЕсли;

	Возврат БазоваяСкидка;

КонецФункции

Функция ЕстьДубли(Таблица) Экспорт

	Результат = Ложь;

	Для Каждого Строка1 Из Таблица Цикл
		Для Каждого Строка2 Из Таблица Цикл
			Если Строка1.Артикул = Строка2.Артикул Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Результат Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции
