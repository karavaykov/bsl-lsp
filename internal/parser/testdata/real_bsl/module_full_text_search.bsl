Процедура ВыполнитьПолнотекстовыйПоиск(ТекстЗапроса, МаксимумРезультатов) Экспорт
	Результаты = Новый СписокЗначений;
	Попытка
		Найденные = ПолнотекстовыйПоиск.Найти(ТекстЗапроса, МаксимумРезультатов);
		Если Найденные.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		Для Счетчик = 0 По Найденные.Количество() - 1 Цикл
			НайденныйОбъект = Найденные.Получить(Счетчик).Значение;
			Результаты.Добавить(НайденныйОбъект.Ссылка, НайденныйОбъект.Представление);
		КонецЦикла;
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка", "Поиск", , "Ошибка полнотекстового поиска: " + ОписаниеОшибки());
	КонецПопытки;
	Возврат Результаты;
КонецПроцедуры
