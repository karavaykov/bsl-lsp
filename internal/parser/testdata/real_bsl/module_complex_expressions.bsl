Процедура ТестСложныеВыражения()
	А = (1 + 2) * (3 - 4) / (5 + 6);
	Б = (А * 2 + 1 > 10) И (А < 100) ИЛИ Не (А = 50);
	В = ?(А > 0, ?(А > 100, "Много", "Мало"), "Ноль");
	Г = (Новый Структура).Свойство;
	Д = ПолучитьОбъект().ПолучитьДанные(1, 2, 3).ЗначениеПоля;
	Е = Массив[0].Значение[1].Вложенное[(Индекс + 1) * 2];
КонецПроцедуры
Функция ВычислитьПоФормуле(Параметры) Экспорт
	Результат = Параметры.База * (1 + Параметры.Процент / 100) ^ Параметры.Период;
	Результат = Результат - Параметры.ЕжемесячныйПлатеж * ((1 + Параметры.Процент / 100) ^ Параметры.Период - 1) / (Параметры.Процент / 100);
	Возврат Окр(Результат, 2);
КонецФункции
