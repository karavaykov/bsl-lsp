Процедура ТестПроизводительности()
	Счетчик = 0;
	Пока Счетчик < 10000 Цикл
		Результат = Счетчик * 2 + 1;
		Счетчик = Счетчик + 1;
	КонецЦикла;
КонецПроцедуры
Функция РекурсивнаяФункция(N) Экспорт
	Если N <= 1 Тогда
		Возврат 1;
	КонецЕсли;
	Возврат N * РекурсивнаяФункция(N - 1);
КонецФункции
Процедура ЦиклСПрерыванием()
	Для Счетчик = 1 По 100 Цикл
		Если Счетчик > 50 Тогда
			Прервать;
		КонецЕсли;
		Если Счетчик % 10 = 0 Тогда
			Продолжить;
		КонецЕсли;
		Сообщить(Счетчик);
	КонецЦикла;
КонецПроцедуры
Процедура ВложенныеЦиклы()
	Сумма = 0;
	Для Индекс1 = 1 По 10 Цикл
		Для Индекс2 = 1 По 10 Цикл
			Для Индекс3 = 1 По 10 Цикл
				Сумма = Сумма + Индекс1 + Индекс2 + Индекс3;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры
