Процедура ОбработкаПроведения(Отказ, Режим)
	Движения.Записать();
	Счетчик = 0;
	Для Счетчик = 1 По Объект.Товары.Количество() Цикл
		ТекСтрока = Объект.Товары.Получить(Счетчик - 1);
		Если ТекСтрока.Сумма = 0 Тогда
			Продолжить;
		КонецЕсли;
		Движение = Движения.Продажи.Добавить();
		Движение.Период = Объект.Дата;
		Движение.Номенклатура = ТекСтрока.Номенклатура;
		Движение.Сумма = ТекСтрока.Сумма;
	КонецЦикла;
	Движения.Записать();
КонецПроцедуры
Процедура ОбработкаУдаленияПроведения(Отказ)
	Счетчик = 0;
	Пока Счетчик < Объект.Товары.Количество() Цикл
		Если Объект.Товары[Счетчик].Сумма > 0 Тогда
			ВызватьИсключение "Нельзя удалить проведение документа с ненулевыми суммами";
		КонецЕсли;
		Счетчик = Счетчик + 1;
	КонецЦикла;
КонецПроцедуры
Процедура ПередЗаписью(Отказ)
	Если Не ЗначениеЗаполнено(Объект.Номер) Тогда
		Объект.Номер = Документы.НумераторДокументов.ПолучитьНомер();
	КонецЕсли;
КонецПроцедуры
