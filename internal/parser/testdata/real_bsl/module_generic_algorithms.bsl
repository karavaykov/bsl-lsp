Функция РекурсивныйОбходДерева(Узел, Глубина) Экспорт
	Результат = Новый Массив;
	Если Глубина > 10 Тогда
		Возврат Результат;
	КонецЕсли;
	Результат.Добавить(Узел.Значение);
	Для Каждого Потомок Из Узел.ДочерниеЭлементы Цикл
		Подрезультат = РекурсивныйОбходДерева(Потомок, Глубина + 1);
		Для Каждого Элемент Из Подрезультат Цикл
			Результат.Добавить(Элемент);
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции
Процедура ОбойтиГрафВШирину(НачальнаяВершина)
	Очередь = Новый Очередь;
	Посещенные = Новый Соответствие;
	Очередь.Добавить(НачальнаяВершина);
	Посещенные.Вставить(НачальнаяВершина, Истина);
	Пока Очередь.Количество() > 0 Цикл
		Текущая = Очередь.Получить();
		Сообщить("Вершина: " + Текущая.Имя);
		Для Каждого Смежная Из Текущая.Смежные Цикл
			Если Не Посещенные.Получить(Смежная) Тогда
				Посещенные.Вставить(Смежная, Истина);
				Очередь.Добавить(Смежная);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры
