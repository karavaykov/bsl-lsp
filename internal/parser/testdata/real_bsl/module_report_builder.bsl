Процедура СформироватьОтчет(ТабличныйДокумент, Расшифровка, СтандартнаяОбработка) Экспорт
	СтандартнаяОбработка = Ложь;
	ТабличныйДокумент.Очистить();
	Макет = ПолучитьМакет("МакетОтчета");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Номенклатура, Количество, Сумма ИЗ Документ.Продажи ГДЕ Дата МЕЖДУ &Нач И &Кон";
	Запрос.УстановитьПараметр("Нач", НачалоПериода);
	Запрос.УстановитьПараметр("Кон", КонецПериода);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	ОбластьДетальных = Макет.ПолучитьОбласть("ДетальныеЗаписи");
	Пока Выборка.Следующий() Цикл
		ОбластьДетальных.Параметры.Номенклатура = Выборка.Номенклатура;
		ОбластьДетальных.Параметры.Количество = Выборка.Количество;
		ОбластьДетальных.Параметры.Сумма = Выборка.Сумма;
		ТабличныйДокумент.Вывести(ОбластьДетальных);
	КонецЦикла;
КонецПроцедуры
