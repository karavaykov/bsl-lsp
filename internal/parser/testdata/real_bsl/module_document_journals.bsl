Процедура ЗаполнитьЖурналДокументов(ИмяЖурнала, ОтборДата)
	Журнал = Документы[ИмяЖурнала];
	Выборка = Журнал.Выбрать(ОтборДата, ОтборДата);
	ТаблицаДокументов = Новый ТаблицаЗначений;
	ТаблицаДокументов.Колонки.Добавить("Номер");
	ТаблицаДокументов.Колонки.Добавить("Дата");
	ТаблицаДокументов.Колонки.Добавить("Сумма");
	ТаблицаДокументов.Колонки.Добавить("Проведен");
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ТаблицаДокументов.Добавить();
		НоваяСтрока.Номер = Выборка.Номер;
		НоваяСтрока.Дата = Выборка.Дата;
		НоваяСтрока.Сумма = Выборка.СуммаДокумента;
		НоваяСтрока.Проведен = Выборка.Проведен;
	КонецЦикла;
	Возврат ТаблицаДокументов;
КонецПроцедуры
Функция ПолучитьСвязанныеДокументы(Ссылка, СписокВидовДокументов) Экспорт
	Результат = Новый Массив;
	Для Каждого ВидДокумента Из СписокВидовДокументов Цикл
		ДокОбъект = Документы[ВидДокумента];
		Выборка = ДокОбъект.ВыбратьПоСсылке(Ссылка);
		Пока Выборка.Следующий() Цикл
			Результат.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции
