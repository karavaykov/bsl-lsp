Процедура СписатьТоварПоПартиям(Номенклатура, КоличествоСписания, Склад)
	Остатки = РегистрыНакопления.ТоварыНаСкладах.ОстаткиНаДату(ТекущаяДата(), , Номенклатура, Склад);
	Если Остатки.КоличествоОстаток < КоличествоСписания Тогда
		ВызватьИсключение "Недостаточно товара на складе";
	КонецЕсли;
	Движение = Движения.СписаниеТоваров.Добавить();
	Движение.Номенклатура = Номенклатура;
	Движение.Склад = Склад;
	Движение.Количество = КоличествоСписания;
	Движение.Период = ТекущаяДата();
КонецПроцедуры
Функция РассчитатьРезерв(Номенклатура, Склад) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ СУММА(Остатки.КоличествоОстаток) ИЗ РегистрНакопления.ТоварыНаСкладах.Остатки ГДЕ Номенклатура = &Номенклатура И Склад = &Склад";
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", Склад);
	Результат = Запрос.Выполнить();
	Возврат Результат.Выбрать().КоличествоОстаток;
КонецФункции
