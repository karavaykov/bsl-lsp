Процедура ЗаполнитьТабличныйДокумент(Документ, Данные)
	Документ.Очистить();
	Макет = ПолучитьМакет("Макет");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	Документ.Вывести(ОбластьШапка);
	ОбластьШапка.Параметры.Дата = ТекущаяДата();
	Для Каждого СтрокаДанных Из Данные Цикл
		ОбластьСтроки = Макет.ПолучитьОбласть("Строка");
		ОбластьСтроки.Параметры.Колонка1 = СтрокаДанных.Наименование;
		ОбластьСтроки.Параметры.Колонка2 = СтрокаДанных.Количество;
		ОбластьСтроки.Параметры.Колонка3 = СтрокаДанных.Сумма;
		Документ.Вывести(ОбластьСтроки);
	КонецЦикла;
	ОбластьИтог = Макет.ПолучитьОбласть("Итог");
	Документ.Вывести(ОбластьИтог);
КонецПроцедуры
Процедура ВывестиДиаграммуВДокумент(Документ, ТаблицаЗначений)
	Диаграмма = Документ.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Диаграмма);
	Диаграмма.Область = "R1C1:R10C10";
	Диаграмма.ТипДиаграммы = ТипДиаграммы.Гистограмма;
	Диаграмма.Источник = ТаблицаЗначений;
КонецПроцедуры
