Процедура СброситьКэшДанных()
	Кэш = Новый КэшДанных;
	Кэш.Очистить();
	Кэш.Установить("ВерсияКэша", ТекущаяДата());
	ЗаписьЖурналаРегистрации("Информация", "Кэш", , "Кэш данных очищен");
КонецПроцедуры
Функция ПолучитьИзКэша(Ключ, ВремяЖизниСекунд, ФабрикаДанных) Экспорт
	Кэш = Новый КэшДанных;
	Значение = Кэш.Получить(Ключ);
	Если Значение = Неопределено Тогда
		Значение = ФабрикаДанных();
		Кэш.Установить(Ключ, Значение, ВремяЖизниСекунд);
	КонецЕсли;
	Возврат Значение;
КонецФункции
