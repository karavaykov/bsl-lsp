Процедура ОбработкаПроведения(Отказ, Режим)
	Движения.Хозрасчетный.Записывать = Истина;
	Для Каждого Строка Из Объект.Проводки Цикл
		Движение = Движения.Хозрасчетный.Добавить();
		Движение.СчетДт = Строка.СчетДт;
		Движение.СчетКт = Строка.СчетКт;
		Движение.Сумма = Строка.Сумма;
		Движение.Содержание = Строка.Содержание;
		Если Строка.СубконтоДт1 <> Неопределено Тогда
			Движение.СубконтоДт1 = Строка.СубконтоДт1;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
