Процедура РассчитатьЗарплату(Сотрудник, Месяц, Год)
	Начисления = Новый ТаблицаЗначений;
	Начисления.Колонки.Добавить("ВидНачисления");
	Начисления.Колонки.Добавить("Сумма");
	Оклад = Константы.ОкладСотрудника.Получить(Сотрудник);
	ОтработаноДней = КалендарныеГрафики.ОсновнойГрафикРаботы.КоличествоРабочихДней(Месяц, Год);
	НормаДней = КалендарныеГрафики.ОсновнойГрафикРаботы.НормаДней(Месяц, Год);
	Если НормаДней > 0 Тогда
		СуммаОклада = Оклад * ОтработаноДней / НормаДней;
	Иначе
		СуммаОклада = 0;
	КонецЕсли;
	Начисления.Добавить().ВидНачисления = "Оклад";
	Начисления.Добавить().Сумма = СуммаОклада;
	ЗаписатьНачисления(Сотрудник, Начисления, Месяц, Год);
КонецПроцедуры
