Процедура РассчитатьИтогиПоМесяцам(НачалоПериода, КонецПериода) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Продажи.Номенклатура,
	|	Период(Продажи.Период, МЕСЯЦ) КАК Месяц,
	|	СУММА(Продажи.СуммаОборот) КАК Сумма
	|ИЗ РегистрНакопления.ПродажиОбороты(&НачалоПериода, &КонецПериода, , ) КАК Продажи
	|СГРУППИРОВАТЬ ПО
	|	Продажи.Номенклатура,
	|	Период(Продажи.Период, МЕСЯЦ)";
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	ТаблицаИтогов = Новый ТаблицаЗначений;
	ТаблицаИтогов.Колонки.Добавить("Месяц");
	ТаблицаИтогов.Колонки.Добавить("Сумма");
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ТаблицаИтогов.Добавить();
		НоваяСтрока.Месяц = Выборка.Месяц;
		НоваяСтрока.Сумма = Выборка.Сумма;
	КонецЦикла;
	Возврат ТаблицаИтогов;
КонецПроцедуры
