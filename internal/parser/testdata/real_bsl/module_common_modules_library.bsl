Функция СтрокаРазделитьПоРазделителю(Строка, Разделитель) Экспорт
	Массив = Новый Массив;
	Пока Истина Цикл
		Поз = Найти(Строка, Разделитель);
		Если Поз = 0 Тогда
			Массив.Добавить(Строка);
			Прервать;
		КонецЕсли;
		Массив.Добавить(Лев(Строка, Поз - 1));
		Строка = Сред(Строка, Поз + СтрДлина(Разделитель));
	КонецЦикла;
	Возврат Массив;
КонецФункции
Функция СтрокаСоединить(Массив, Разделитель) Экспорт
	Результат = "";
	Для Счетчик = 0 По Массив.Количество() - 1 Цикл
		Если Счетчик > 0 Тогда
			Результат = Результат + Разделитель;
		КонецЕсли;
		Результат = Результат + Массив[Счетчик];
	КонецЦикла;
	Возврат Результат;
КонецФункции
Функция ТаблицаЗначенийВМассивСтруктур(Таблица) Экспорт
	Массив = Новый Массив;
	Колонки = Таблица.Колонки;
	Для Каждого Строка Из Таблица Цикл
		СтруктураСтроки = Новый Структура;
		Для Каждого Колонка Из Колонки Цикл
			СтруктураСтроки.Вставить(Колонка.Имя, Строка[Колонка.Имя]);
		КонецЦикла;
		Массив.Добавить(СтруктураСтроки);
	КонецЦикла;
	Возврат Массив;
КонецФункции
Функция СопоставитьОбъектыПоРеквизиту(МассивОбъектов, ИмяРеквизита) Экспорт
	Соответствие = Новый Соответствие;
	Для Каждого Объект Из МассивОбъектов Цикл
		Ключ = Объект[ИмяРеквизита];
		Соответствие.Вставить(Ключ, Объект);
	КонецЦикла;
	Возврат Соответствие;
КонецФункции
Функция СортироватьМассивСтруктур(Массив, ИмяПоля, Направление) Экспорт
	Если Направление = "Убыв" Тогда
		Массив.СортироватьПоУбыванию(ИмяПоля);
	Иначе
		Массив.СортироватьПоВозрастанию(ИмяПоля);
	КонецЕсли;
	Возврат Массив;
КонецФункции
