Функция ОбработкаHTTPЗапроса(Запрос) Экспорт
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	ИмяМетода = Запрос.Метод;
	Если ИмяМетода = "GET" Тогда
		Данные = ПолучитьДанныеДляОтвета(Запрос.Параметры);
		Ответ.УстановитьТелоИзСтроки(Данные);
	ИначеЕсли ИмяМетода = "POST" Тогда
		ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
		ОбработатьВходящиеДанные(ТелоЗапроса);
		Ответ.УстановитьТелоИзСтроки("""OK""");
	Иначе
		Ответ.КодСостояния = 405;
	КонецЕсли;
	Возврат Ответ;
КонецФункции
