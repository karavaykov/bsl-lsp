Процедура ОбработкаВыбораИзСписка(ВыбранноеЗначение, ИсточникВыбора)
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Элементы.ВыбранныйОбъект.Значение = ВыбранноеЗначение;
	Элементы.ВыбранныйОбъект.Заголовок = ВыбранноеЗначение.Наименование;
КонецПроцедуры
Процедура ОбработкаНачалаВыбора(ДанныеВыбора, Выбор, Ожидание)
	ДанныеВыбора.Очистить();
	ДанныеВыбора.Добавить(Справочники.Номенклатура.ПустаяСсылка(), "Не выбрано");
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Ссылка, Наименование ИЗ Справочник.Номенклатура ГДЕ ПометкаУдаления = Ложь";
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДанныеВыбора.Добавить(Выборка.Ссылка, Выборка.Наименование);
	КонецЦикла;
КонецПроцедуры
Процедура ПриИзмененииДаты()
	Попытка
		ОбновитьДанныеФормы();
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка", "Форма", , ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры
Процедура ОбработкаОбновленияФормы()
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		Элементы.КомандаРедактировать.Доступность = Истина;
		Элементы.КомандаУдалить.Доступность = Не ТекущиеДанные.ПометкаУдаления;
	КонецЕсли;
КонецПроцедуры
